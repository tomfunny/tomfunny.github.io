---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  categories?: string[];
  image?: string;
}

const { title, description, pubDate, updatedDate, tags = [], categories = [], image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description} image={image}>
  <Header slot="header" />
  
  <article class="blog-post">
    <header class="post-header">
      <h1>{title}</h1>
      
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {updatedDate && (
          <span class="updated">
            · 更新于 {formattedUpdatedDate}
          </span>
        )}
      </div>
      
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>
    
    <div class="post-content">
      <slot />
    </div>
  </article>
  
  <Footer slot="footer" />
</Layout>

<style>
  .blog-post {
    padding: 3rem 0;
  }
  
  .post-header {
    margin-bottom: 3rem;
  }
  
  .post-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .post-meta {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
  
  .updated {
    font-style: italic;
  }
  
  .tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .tag {
    background-color: var(--color-card-bg);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    color: var(--color-primary);
    transition: background-color 0.2s ease;
  }
  
  .tag:hover {
    background-color: var(--color-primary);
    color: white;
  }
  
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }
  
  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .post-content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
</style>
