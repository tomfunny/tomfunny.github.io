---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// 准备搜索数据
const searchData = posts.map((post) => ({
  href: `/blog/${post.id}/`,
  title: post.data.title,
  excerpt: post.data.description || post.body.slice(0, 150) + '...',
  date: post.data.pubDate.toLocaleDateString('zh-CN'),
  tags: post.data.tags || [],
}));

const searchDataJson = JSON.stringify(searchData);
---

<div class="search-modal" id="searchModal">
  <div class="search-overlay"></div>
  <div class="search-content">
    <div class="search-header">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input 
        type="text" 
        class="search-input" 
        id="searchInput"
        placeholder="搜索文章标题或内容..."
        autocomplete="off"
      />
      <button type="button" class="search-close" id="searchClose" aria-label="关闭搜索">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="search-results" id="searchResults"></div>
    <div class="search-footer">
      <span>按 <kbd>Enter</kbd> 搜索，<kbd>Esc</kbd> 关闭</span>
    </div>
  </div>
</div>

<style>
  .search-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
  }
  
  .search-modal.active {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }
  
  .search-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  
  .search-content {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 1.5rem;
    background: var(--color-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  
  .search-header {
    display: flex;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }
  
  .search-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  
  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1.125rem;
    color: var(--color-text);
    outline: none;
  }
  
  .search-input::placeholder {
    color: var(--color-text-muted);
  }
  
  .search-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: var(--color-card-bg);
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: var(--radius);
    transition: all 0.2s ease;
  }
  
  .search-close:hover {
    background: var(--color-border);
  }
  
  .search-results {
    max-height: 50vh;
    overflow-y: auto;
    padding: 0.5rem 0;
  }
  
  .search-result-item {
    padding: 1rem 1.5rem;
    transition: background-color 0.2s ease;
  }
  
  .search-result-item:hover {
    background-color: var(--color-card-bg);
  }
  
  .search-result-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  
  .search-result-item h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }
  
  .search-result-item:hover h3 {
    color: var(--color-primary);
  }
  
  .search-result-item p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .search-result-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  
  .search-result-tags {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  
  .search-result-tag {
    background-color: var(--color-card-bg);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    color: var(--color-primary);
  }
  
  .search-no-results {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem 1.5rem;
  }
  
  .search-footer {
    padding: 0.75rem 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  kbd {
    background-color: var(--color-card-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.6875rem;
    border: 1px solid var(--color-border);
  }
</style>

<script>
  const posts = {setData:searchData};
  const searchModal = document.getElementById('searchModal');
  const searchInput = document.getElementById('searchInput');
  const searchClose = document.getElementById('searchClose');
  const searchResults = document.getElementById('searchResults');
  
  function openSearch() {
    searchModal?.classList.add('active');
    setTimeout(() => searchInput?.focus(), 100);
  }
  
  function closeSearch() {
    searchModal?.classList.remove('active');
    searchInput.value = '';
    searchResults.innerHTML = '';
  }
  
  function highlightMatch(text: string, query: string) {
    if (!query) return text;
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(regex, '<mark>$1</mark>');
  }
  
  function search(query: string) {
    if (!query.trim()) {
      searchResults.innerHTML = '';
      return;
    }
    
    const queryLower = query.toLowerCase();
    const results = posts.filter((post: any) => 
      post.title.toLowerCase().includes(queryLower) ||
      post.excerpt.toLowerCase().includes(queryLower) ||
      post.tags?.some((tag: string) => tag.toLowerCase().includes(queryLower))
    );
    
    if (results.length === 0) {
      searchResults.innerHTML = '<p class="search-no-results">没有找到相关文章</p>';
      return;
    }
    
    searchResults.innerHTML = results.map((post: any) => `
      <div class="search-result-item">
        <a href="${post.href}">
          <h3>${highlightMatch(post.title, query)}</h3>
          <p>${highlightMatch(post.excerpt, query)}</p>
          <div class="search-result-meta">
            <time>${post.date}</time>
            ${post.tags?.length > 0 ? `
              <div class="search-result-tags">
                ${post.tags.slice(0, 3).map((tag: string) => `<span class="search-result-tag">#${tag}</span>`).join('')}
              </div>
            ` : ''}
          </div>
        </a>
      </div>
    `).join('');
  }
  
  // 导出打开搜索的函数供 Header 调用
  (window as any).openSearch = openSearch;
  
  searchClose?.addEventListener('click', closeSearch);
  searchModal?.querySelector('.search-overlay')?.addEventListener('click', closeSearch);
  searchInput?.addEventListener('input', (e: Event) => search((e.target as HTMLInputElement).value));
  
  // 快捷键：Cmd/Ctrl + K 打开搜索
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') {
      closeSearch();
    }
  });
</script>
